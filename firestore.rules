rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(boardId) {
      return isSignedIn()
        && request.auth.uid == get(/databases/$(database)/documents/boards/$(boardId)).data.get('ownerId', null);
    }

    function isMember(boardId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/boards/$(boardId)).data.get('memberIds', []);
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isTeenUser() {
      return getUserDoc().ageGroup == 'teen';
    }

    // ─── Users ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();

      // Create: must set required fields with correct types
      allow create: if isSignedIn() && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['uid', 'displayName', 'email'])
        && request.resource.data.uid == userId
        && request.resource.data.displayName is string
        && request.resource.data.email is string;

      // Update: cannot change uid; validate optional digest fields
      allow update: if isSignedIn() && request.auth.uid == userId
        && request.resource.data.get('uid', resource.data.uid) == resource.data.uid
        && (request.resource.data.get('digestEnabled', true) is bool)
        && (request.resource.data.get('digestTime', '07:30') is string)
        && (request.resource.data.get('digestTimezone', 'UTC') is string);

      // Delete: only own account
      allow delete: if isSignedIn() && request.auth.uid == userId;

      match /tokens/{tokenId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      // Consolidated read-state doc (per-board lastReadAt timestamps)
      match /readState/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      // On This Day memories (written by Cloud Functions)
      match /memories/{memoryId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // ─── Boards ────────────────────────────────────────────────────────
    match /boards/{boardId} {
      // Only members can read boards (private-only social graph — Lever 1)
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.get('memberIds', []);

      // Anyone authed can create, but must set themselves as owner
      // Field-level type validation for BoardDoc shape (isPublic must be false)
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.keys().hasAll(['name', 'ownerId', 'memberIds', 'isPublic', 'template', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.template is string
        && request.resource.data.memberIds is list
        && request.resource.data.createdAt is timestamp
        && request.resource.data.isPublic == false;

      // Members can update, but only owner can change ownerId or memberIds
      // Exception: a signed-in user with a valid pending invite can add themselves to memberIds
      // isPublic must always remain false (private-only social graph)
      allow update: if isSignedIn()
        && (request.resource.data.ownerId == resource.data.ownerId)
        && (
          // Normal member update (no memberIds change, or owner changing memberIds)
          (request.auth.uid in resource.data.memberIds
            && (request.resource.data.memberIds == resource.data.memberIds
                || request.auth.uid == resource.data.ownerId))
          // Invite join: non-member adds only themselves to memberIds
          || (!(request.auth.uid in resource.data.memberIds)
              && request.resource.data.memberIds.hasAll(resource.data.memberIds)
              && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
              && request.auth.uid in request.resource.data.memberIds
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'pendingInviteCount']))
        )
        && request.resource.data.isPublic == false;

      // Only owner can delete
      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;

      // ─── Members subcollection ─────────────────────────────────────
      match /members/{memberId} {
        // Only members can read member docs (private-only social graph)
        allow read: if isMember(boardId);
        // Owner can manage all members; members can create/update their own doc (e.g. notificationMode, lastReadAt)
        allow create: if isOwner(boardId)
          || (isSignedIn() && request.auth.uid == memberId);
        allow delete: if isOwner(boardId);
        allow update: if isOwner(boardId)
          || (isSignedIn() && request.auth.uid == memberId);
      }

      // ─── Content ───────────────────────────────────────────────────
      match /content/{contentId} {
        // Only members can read content (private-only social graph)
        allow read: if isMember(boardId);
        // Field-level type validation for ContentDoc shape
        // Lever 7 (Agent guardrails): Requires userIntent field for all content creation
        allow create: if isMember(boardId)
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.moderationStatus == 'approved'
          && request.resource.data.keys().hasAll(['type', 'authorId', 'authorName', 'createdAt', 'userIntent'])
          && request.resource.data.type is string
          && request.resource.data.authorId is string
          && request.resource.data.authorName is string
          && request.resource.data.createdAt is timestamp
          && request.resource.data.userIntent is string
          && request.resource.data.userIntent.size() > 0
          // Note/voice text max 10,000 chars; list title max 200 chars
          && (request.resource.data.get('text', '') is string
              && request.resource.data.get('text', '').size() <= 10000)
          && (request.resource.data.get('title', '') is string
              && request.resource.data.get('title', '').size() <= 200);

        // Author can update own content (but not moderationStatus)
        // Board owner can update any content (including moderationStatus)
        allow update: if isMember(boardId)
          && (
            request.auth.uid == resource.data.authorId
            || isOwner(boardId)
            || (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['acknowledgments'])
              && request.resource.data.acknowledgments.diff(resource.data.get('acknowledgments', {})).affectedKeys().hasOnly([request.auth.uid])
            )
          )
          && (request.resource.data.moderationStatus == resource.data.moderationStatus
              || isOwner(boardId));

        allow delete: if isMember(boardId)
          && (request.auth.uid == resource.data.authorId
              || isOwner(boardId));

        match /votes/{voteId} {
          // Only members can read votes (private-only social graph)
          allow read: if isMember(boardId);
          // One vote per user — voteId must equal auth uid
          allow create: if isSignedIn() && request.auth.uid == voteId && isMember(boardId);
          // Cannot change or delete votes
          allow update, delete: if false;
        }

        match /comments/{commentId} {
          // Only members can read comments (private-only social graph)
          allow read: if isMember(boardId);

          // Must be member, author must be self, max 280 chars, rate limit 10s
          allow create: if isMember(boardId)
            && request.resource.data.authorId == request.auth.uid
            && request.resource.data.text.size() <= 280
            && exists(/databases/$(database)/documents/boards/$(boardId)/members/$(request.auth.uid))
            && (request.time - get(/databases/$(database)/documents/boards/$(boardId)/members/$(request.auth.uid)).data.get('lastCommentAt', timestamp.value(0))).seconds() >= 10;

          // Only author or board owner can delete
          allow delete: if isMember(boardId)
            && (request.auth.uid == resource.data.authorId || isOwner(boardId));

          allow update: if false; // Comments are immutable in V3
        }
      }

      // ─── Join Requests ────────────────────────────────────────────
      match /joinRequests/{requestId} {
        // Owner reads all; requester reads own
        allow read: if isOwner(boardId)
          || (isSignedIn() && resource.data.requesterId == request.auth.uid);

        // Any authed user can create their own request
        allow create: if isSignedIn()
          && request.resource.data.requesterId == request.auth.uid
          && request.resource.data.status == 'pending'
          && request.resource.data.keys().hasAll(['boardId', 'requesterId', 'requesterName', 'requesterPhotoURL', 'status', 'requestedAt']);

        // Only owner can approve/reject
        allow update: if isOwner(boardId);

        // Only owner can delete
        allow delete: if isOwner(boardId);
      }

      // ─── Invites ──────────────────────────────────────────────────
      match /invites/{inviteId} {
        // Members of the board can see pending invites (to see they were sent)
        allow read: if (isSignedIn() && exists(/databases/$(database)/documents/boards/$(boardId)/members/$(request.auth.uid))) || isOwner(boardId) || (isSignedIn() && request.auth.token.email == resource.data.contactIdentifier);
        allow create: if isOwner(boardId);
        // Owner can manage invites; invited user can mark as 'joined'
        allow update: if isOwner(boardId)
          || (isSignedIn()
              && request.resource.data.status == 'joined'
              && resource.data.status == 'pending');
        allow delete: if isOwner(boardId);
      }

      // ─── Briefings ─────────────────────────────────────────────────
      match /briefings/{briefingId} {
        // Only members can read briefings (private-only social graph)
        allow read: if isMember(boardId);
        // Only Cloud Functions write briefings (admin SDK bypasses rules)
        allow write: if false;
      }

      // ─── Smart Reminders (sent by Cloud Functions) ────────────────
      match /reminders_sent/{reminderId} {
        allow read: if isMember(boardId);
        allow write: if false;
      }

      // ─── Wrapped (year in review) ─────────────────────────────────
      match /wrapped/{year} {
        allow read: if isMember(boardId);
        // Only Cloud Functions write wrapped docs
        allow write: if false;
      }
    }

    // ─── Price tracking ──────────────────────────────────────────────
    match /prices/{priceId} {
      // Any authed user can read (product cards display price data)
      allow read: if isSignedIn();
      // Only allow creating price tracking entries with a valid boardId where user is a member
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['productUrl', 'boardId', 'contentId'])
        && isMember(request.resource.data.boardId);
      // Only members of the associated board can update (price history appends)
      allow update: if isSignedIn() && isMember(resource.data.boardId);
      allow delete: if false;
    }

    // ─── Templates marketplace ───────────────────────────────────────
    match /templates/{templateId} {
      allow read: if isSignedIn();
      // Creator must be the authenticated user
      allow create: if isSignedIn()
        && request.resource.data.creatorId == request.auth.uid
        && request.resource.data.keys().hasAll(['name', 'description', 'category', 'creatorId', 'creatorName', 'sections', 'cloneCount'])
        && (!('isCurated' in request.resource.data.keys()) || request.resource.data.isCurated == false);
      // Only creator can update or delete their template
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.creatorId
        && request.resource.data.creatorId == resource.data.creatorId
        && (!('isCurated' in request.resource.data.keys()) || request.resource.data.isCurated == resource.data.isCurated);
      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.creatorId;
    }

    // ─── Global Content Cache ──────────────────────────────────────────
    match /globalContent/{contentHash} {
      // Any authenticated user can read (for future client-side joins)
      allow read: if isSignedIn();
      // Only Cloud Functions write via admin SDK — never client-writable
      allow write: if false;
    }
  }
}
