# Firebase — required for Firebase init (src/lib/firebase/index.ts)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# FCM Push Notifications — VAPID key from Firebase Console > Cloud Messaging
VITE_FIREBASE_VAPID_KEY=

# Firebase App Check (optional — disables App Check if not set)
VITE_RECAPTCHA_SITE_KEY=

# Affiliate providers (optional — returns original URLs if not set)
VITE_AMAZON_ASSOCIATE_TAG=
VITE_SKIMLINKS_PUBLISHER_ID=
VITE_SOVRN_API_KEY=

# Groq AI (required for Cloud Functions: briefings, reminders, wrapped)
GROQ_API_KEY=
