rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── AVATARS ──────────────────────────────────────────────────────
    // Users can read any avatar (displayed on cards/profiles).
    // Users can only write their own avatar.
    match /users/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ─── BOARD CONTENT (voice, photos, videos) ───────────────────────
    // Any authenticated user can read (download URLs are scoped via token).
    // Any authenticated user can write — Firestore rules enforce board membership.
    match /boards/{boardId}/voice/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('audio/.*');
    }

    match /boards/{boardId}/photos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /boards/{boardId}/videos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024
                   && request.resource.contentType.matches('video/.*');
    }

    // ─── BRIEFINGS (written by Cloud Functions via Admin SDK) ─────────
    // Authenticated users can read briefing audio (download URLs are scoped via token).
    // No client writes — only Admin SDK writes these.
    match /boards/{boardId}/briefings/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── TEMP COVERS ─────────────────────────────────────────────────
    // Authenticated users can upload board covers to temp/.
    match /temp/covers/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ─── DENY EVERYTHING ELSE ────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
