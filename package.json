    "firebase-admin": "^13.7.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.4"
  },
  "dependencies": {
